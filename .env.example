OPENROUTER_API_KEY=

# ローカルSupabase Postgres（supabase start 後のDB URL）
# 設定しない場合、月次レポートAPIはin-memoryモックストアを使う
EB_MONTHLY_REPORT_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:56322/postgres

# Supabase Auth JWT検証。本番/実OAuth E2EではSupabase projectのJWT secretをSecret Manager等から渡す。
# ローカルmock開発では EB_AUTH_MODE=mock を使い、通常は設定不要。
# EB_MOCK_USER_EMAIL=y-haraguchi@tomonokai-corp.com
# 保存済みGoogle OAuth credentialをmock UIから使う場合のみ、Supabase Auth user UUIDを指定する。
# EB_MOCK_USER_ID=
# SUPABASE_JWT_SECRET=
# SUPABASE_JWT_AUDIENCE=authenticated
# EB_ALLOWED_EMAIL_DOMAIN=tomonokai-corp.com

# レポート本文生成（自然な日本語優先）— Sonnet / Opus 系を推奨。OpenRouter のモデル一覧で ID を確認すること。
OPENROUTER_MODEL_REPORT=anthropic/claude-sonnet-4.6
# OPENROUTER_MODEL_REPORT=anthropic/claude-opus-4.7

# 後述ツールで軽量タスク（抽出・分類・検証プロンプトの下準備など）に使う廉価モデル（レポート本体には使わない想定）
OPENROUTER_MODEL_LIGHT=google/gemini-2.0-flash-001

# 後方互換: OPENROUTER_MODEL_REPORT が無いときのみフォールバックとして参照される
# OPENROUTER_MODEL=

# 再現性メタ。未設定でも既定値で動くが、E2E/チューニング比較では明示推奨。
EB_MONTHLY_REPORT_PROMPT_VERSION=monthly-report-v20260517.1
EB_APP_VERSION=local-dev

# ローカル開発用: Google Workspace REST API疎通確認用の一時access token。
# 本番ではリクエストbodyやフロントに置かず、暗号化保存したユーザーOAuth provider tokenから取得する。
# EB_GOOGLE_WORKSPACE_ACCESS_TOKEN=

# Google OAuth provider token更新用。本番ではSecret Manager等から渡す。
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# EB_GOOGLE_TOKEN_ENCRYPTION_KEY=  # Fernet key
# EB_GOOGLE_TOKEN_ENCRYPTION_KEY_VERSION=local-v1

# Supabase Google provider ライブE2E用。URL / anon key は公開可能値だが、実値は必要な環境だけに置く。
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# EB_GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/documents.readonly https://www.googleapis.com/auth/spreadsheets.readonly https://www.googleapis.com/auth/drive.readonly

# staging 用の代表値。local Supabase と切り替える場合は、下の staging 値を使う。
# EB_ENV=staging
# EB_AUTH_MODE=supabase
# SUPABASE_URL=https://jtnmjmayuazocqpxajis.supabase.co
# SUPABASE_ANON_KEY=
# SUPABASE_JWT_SECRET=
# EB_MONTHLY_REPORT_DATABASE_URL=
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# EB_GOOGLE_TOKEN_ENCRYPTION_KEY=
# EB_GOOGLE_TOKEN_ENCRYPTION_KEY_VERSION=staging-v1
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL_REPORT=anthropic/claude-sonnet-4.6
# OPENROUTER_MODEL_LIGHT=google/gemini-2.0-flash-001
# OPENROUTER_TIMEOUT=120
# EB_MONTHLY_REPORT_PROMPT_VERSION=monthly-report-v20260517.1
# EB_APP_VERSION=staging-bootstrap
